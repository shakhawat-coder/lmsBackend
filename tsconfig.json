{
  "compilerOptions": {
    "module": "esnext", 
    "moduleResolution": "bundler",     
     "target": "ES2023",                          
    "outDir": "./dist",  
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    // "ignoreDeprecations": "6.0"
  },
  "include": [
    "./src",
    "./prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
  
}


